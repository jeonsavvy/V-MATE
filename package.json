{
  "name": "v-mate",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "start": "node server/cloud-run-server.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:server && npm run test:ui",
    "test:server": "node server/run-tests.js",
    "test:ui": "vitest run",
    "verify": "npm run typecheck && npm test && npm run build",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cf:dev": "npm run build && npx --yes wrangler@4.67.0 dev",
    "cf:deploy": "npm run build && npx --yes wrangler@4.67.0 deploy",
    "cf:typegen": "npx --yes wrangler@4.67.0 types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@supabase/supabase-js": "^2.39.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.303.0",
    "motion": "^12.35.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sonner": "^1.4.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.5",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.16",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.7"
  }
}
